{
  "name": "@alirezahadjar/monorepo",
  "private": true,
  "version": "0.9.1",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf node_modules",
    "docs": "turbo docs --filter=docs",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "postinstall": "sh ./scripts/postinstall.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlirezaHadjar/expo-drag-drop-content-view.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@manypkg/cli": "^0.24.0",
    "@typescript-eslint/typescript-estree": "^8.35.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.6.2",
    "react-loadable": "npm:@docusaurus/react-loadable@5.5.2",
    "turbo": "^2.5.4",
    "typescript": "~6.0.3"
  }
}
